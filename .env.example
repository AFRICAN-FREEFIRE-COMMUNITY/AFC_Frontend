# AFC Frontend — environment template
# Copy to .env.local for development.

# Required — the backend Django API base URL
NEXT_PUBLIC_BACKEND_API_URL=https://api.africanfreefirecommunity.com

# Required — this frontend's public origin
NEXT_PUBLIC_URL=http://localhost:3000

# Wager feature — set to 1 to run the frontend with the in-browser mock data
# layer (no backend required). Recommended for local demo. Set to 0 (or unset)
# in production to hit the real Django wager/wallet APIs.
NEXT_PUBLIC_WAGER_MOCK=1
